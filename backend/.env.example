# Backend environment variables for ETradie

# PostgreSQL connection string, e.g.
# DATABASE_URL="postgresql://user:password@localhost:5432/etradie?schema=public"
DATABASE_URL=

# Secret used to sign JWTs. Use a long random string in production.
JWT_SECRET=changeme-in-production

# Port for the Express/Socket.IO server to listen on.
PORT=4000

# URL of the React frontend (used by CORS and Socket.IO).
CLIENT_URL=http://localhost:5173

# API key for the OpenCage geocoding API
OPENCAGE_API_KEY=

